# ─── Bot ────────────────────────────────────────────────────────────────────
BOT_PHONE=5517988410596
OWNER_NUMBERS=5517920043856
OWNER_LIDS=

# ─── Dashboard / Webhook ────────────────────────────────────────────────────
PORT=3000
# Porta do servidor HTTP que recebe webhooks da Evolution API e serve o dashboard

# ─── Webhook Security & Dedup ───────────────────────────────────────────────
# Validação de autenticidade do webhook
# EVOLUTION_WEBHOOK_VALIDATE=true ativa a validação da chave recebida nos webhooks
# EVOLUTION_WEBHOOK_SECRET: pode ser igual à EVOLUTION_API_KEY (chave global da Evolution)
#
# IMPORTANTE — Evolution 2.x usa tokens por instância (diferentes da API key global):
#   - O token da instância é buscado automaticamente no boot via /instance/fetchInstances
#   - Ele é adicionado como candidato válido automaticamente (state.instanceToken)
#   - Portanto: basta configurar EVOLUTION_API_KEY corretamente; o token de instância
#     é resolvido sozinho. EVOLUTION_WEBHOOK_SECRET pode ser idêntico ao API_KEY.
EVOLUTION_WEBHOOK_VALIDATE=true
EVOLUTION_WEBHOOK_SECRET=

# Deduplicação de mensagens (evita processar a mesma mensagem várias vezes)
WEBHOOK_DEDUP_ENABLED=true
WEBHOOK_DEDUP_TTL_MS=180000
WEBHOOK_DEDUP_MAX_IDS=10000

# ─── IA ─────────────────────────────────────────────────────────────────────
# Chaves principais para conversa
GEMINI_KEY_1=
GEMINI_KEY_2=

# Chaves dedicadas para análise NSFW
NSFW_GEMINI_KEY_1=
NSFW_GEMINI_KEY_2=

# Chave de fallback global (usada se as principais falharem)
GEMINI_FALLBACK_KEY=

# Chave Groq (fallback final para texto)
GROQ_KEY=

# ─── Anti-NSFW ──────────────────────────────────────────────────────────────
NSFW_ENABLED=true
NSFW_PROVIDER=gemini
NSFW_FAIL_OPEN=true
NSFW_TIMEOUT_MS=15000
NSFW_MAX_IMAGE_MB=8
NSFW_THRESHOLD_BLOCK=0.85
NSFW_THRESHOLD_REVIEW=0.60

# ─── Integrações ─────────────────────────────────────────────────────────────
DISCORD_WEBHOOK_URL=
BOOT_MESSAGE=

# ─── Evolution API ───────────────────────────────────────────────────────────
# URL da sua instância da Evolution API (ex: http://localhost:8080 ou https://evolution.seudominio.com)
EVOLUTION_API_URL=http://192.168.1.236:8080
# Chave de API global da Evolution (configurada no arquivo .env da Evolution)
EVOLUTION_API_KEY=
# Nome da instância criada na Evolution API (ex: mahito-evo)
EVOLUTION_INSTANCE=mahito-evo

# ENABLE_EVOLUTION=true  → Modo Evolution API (webhook-only, sem Baileys) — RECOMENDADO
# ENABLE_EVOLUTION=false → Modo Baileys legado (requer sessão QR, funcionalidades limitadas)
ENABLE_EVOLUTION=true

# ─── Logger ──────────────────────────────────────────────────────────────────
# Níveis: DEBUG | INFO | WARN | ERROR
LOG_LEVEL=INFO
